{
  // Cloudflare Worker config for the sevDesk Remote MCP server.
  // Deploys independently from the local Claude Desktop stdio MCP server.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "eneto-sevdesk-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "SEVDESK_BASE_URL": "https://my.sevdesk.de/api/v1",
    "SEVDESK_USER_AGENT": "workflow-mcp remote Cloudflare Worker",
    "SEVDESK_DEFAULT_CONTACT_CATEGORY_ID": "3",
    "SEVDESK_DEFAULT_COUNTRY_ID": "1",
    "SEVDESK_DEFAULT_UNITY_ID": "1"
  },
  "secrets": {
    "required": ["SEVDESK_API_TOKEN"]
  }
  // Secrets are set with Wrangler and must never be committed:
  //   wrangler secret put SEVDESK_API_TOKEN
}
