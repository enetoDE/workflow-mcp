{
  "name": "workflow-mcp",
  "version": "1.0.0",
  "description": "Local workflow and business integrations MCP server for Claude Desktop",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "workflow-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "worker:install": "npm --prefix worker install",
    "worker:dev": "npm --prefix worker run dev",
    "worker:typecheck": "npm --prefix worker run typecheck",
    "worker:deploy": "npm --prefix worker run deploy"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0"
  }
}
